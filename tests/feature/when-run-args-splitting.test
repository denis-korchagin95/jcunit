@test("It should split args by space into separate arguments")
@given("none")
@whenRun("./testers/print-args", args="--flag1 --flag2")
@expectOutput("stdout")
--flag1
--flag2

@endtest

@test("It should pass a single arg correctly")
@given("none")
@whenRun("./testers/print-args", args="--only-flag")
@expectOutput("stdout")
--only-flag

@endtest

@test("It should split multiple args correctly")
@given("none")
@whenRun("./testers/print-args", args="--flag1 --flag2 --flag3")
@expectOutput("stdout")
--flag1
--flag2
--flag3

@endtest

@test("It should handle multiple consecutive spaces between args")
@given("none")
@whenRun("./testers/print-args", args="--flag1  --flag2")
@expectOutput("stdout")
--flag1
--flag2

@endtest

@test("It should handle leading and trailing spaces in args")
@given("none")
@whenRun("./testers/print-args", args=" --flag1 --flag2 ")
@expectOutput("stdout")
--flag1
--flag2

@endtest

@test("It should handle tab as delimiter in args")
@given("none")
@whenRun("./testers/print-args", args="--flag1	--flag2")
@expectOutput("stdout")
--flag1
--flag2

@endtest
