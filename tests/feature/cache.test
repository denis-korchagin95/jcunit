@test("It should produce the same output with --no-cache as without it")
@given("file", filename="some-test.test")

@@test("A passed test")
@@given("file")

@@@@test()
@@@@endtest()

@@whenRun("./bin/jcunit")
@@expectOutput("stderr")
There is no any requirement provided for test!

@@endtest

@whenRun("./bin/jcunit", args="--no-cache")
@expectOutput("stdout")
.                                                  (100%)

Time: {{any}}
OK!
Passed: 1, Skipped: 0, Errors: 0, Failed: 0, Incomplete: 0

@endtest

