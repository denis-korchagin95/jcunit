@test("It should produce same results in detail mode with --no-cache")
@given("file", filename="some-test.test")

@@test("A passed test")
@@given("file")

@@@@test()
@@@@endtest()

@@whenRun("./bin/jcunit")
@@expectOutput("stderr")
There is no any requirement provided for test!

@@endtest

@@test("An error test")
@@given("file")
@@whenRun("./bin/some-program")
@@expectOutput("stdout")
@@endtest

@whenRun("./bin/jcunit", args="--no-cache")
@expectOutput("stdout")
.E                                                 (100%)

There are 1 errors:

1) some-test.test : An error test
The file "./bin/some-program" was not found!

Time: {{any}}
FAILED!
Passed: 1, Skipped: 0, Errors: 1, Failed: 0, Incomplete: 0

@endtest

@test("It should not serve stale cache when file content changes with the same name")
@given("file", filename="cache-collision.test")

@@test("First test")
@@given("file")

@@@@test()
@@@@endtest()

@@whenRun("./bin/jcunit")
@@expectOutput("stderr")
There is no any requirement provided for test!

@@endtest

@whenRun("./bin/jcunit")
@expectOutput("stdout")
.                                                  (100%)

Time: {{any}}
OK!
Passed: 1, Skipped: 0, Errors: 0, Failed: 0, Incomplete: 0

@endtest

@test("It should use fresh content after the same filename was rewritten")
@given("file", filename="cache-collision.test")

@@test("Second test")
@@given("file")
@@whenRun("./bin/testers/tokenizer-tester")
@@expectOutput("stdout")
<TOKEN_EOF>

@@endtest

@whenRun("./bin/jcunit")
@expectOutput("stdout")
.                                                  (100%)

Time: {{any}}
OK!
Passed: 1, Skipped: 0, Errors: 0, Failed: 0, Incomplete: 0

@endtest

@test("It should handle --no-cache with skipped tests")
@given("file", filename="some-test.test")

@@test("A skipped test")
@@shouldBeSkipped
@@given("file")
@@whenRun("./bin/testers/tokenizer-tester")
@@expectOutput("stdout")
<TOKEN_EOF>

@@endtest

@whenRun("./bin/jcunit", args="--no-cache")
@expectOutput("stdout")
S                                                  (100%)

Time: {{any}}
OK, but some tests were skipped or incomplete!
Passed: 0, Skipped: 1, Errors: 0, Failed: 0, Incomplete: 0

@endtest
