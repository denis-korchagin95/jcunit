@test("It should pass when both stdout and stderr match")
@given("file")
@whenRun("./testers/dual-output.sh")
@expectOutput("stdout")
stdout line
@expectOutput("stderr")
stderr line
@endtest

@test("It should fail when stdout does not match but stderr matches")
@given("file")

@@test("A dual output test")
@@given("file")
@@whenRun("./testers/dual-output.sh")
@@expectOutput("stdout")
wrong stdout
@@expectOutput("stderr")
stderr line
@@endtest

@whenRun("./bin/jcunit")
@expectOutput("stdout")
F                                                  (100%)

