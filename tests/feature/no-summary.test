@test("It should suppress summary in passthrough mode with --no-summary")
@given("file")

@@test("A passed test")
@@given("file")

@@@@test()
@@@@endtest()

@@whenRun("./bin/jcunit")
@@expectOutput("stderr")
There is no any requirement provided for test!

@@endtest

@whenRun("./bin/jcunit", args="--no-summary")
@expectOutput("stdout")
.                                                  (100%)

Passed: 1, Skipped: 0, Errors: 0, Failed: 0, Incomplete: 0

@endtest


@test("It should suppress summary in passthrough mode with errors and --no-summary")
@given("file", filename="some-test.test")

@@test("An error test")
@@given("file")
@@whenRun("./bin/some-program")
@@expectOutput("stdout")
@@endtest

@whenRun("./bin/jcunit", args="--no-summary")
@expectOutput("stdout")
E                                                  (100%)

There are 1 errors:

1) some-test.test : An error test
The file "./bin/some-program" was not found!

Passed: 0, Skipped: 0, Errors: 1, Failed: 0, Incomplete: 0

@endtest


@test("It should suppress summary in detail mode with --no-summary")
@given("file", filename="some-test.test")

@@test("A passed test")
@@given("file")

@@@@test()
@@@@endtest()

@@whenRun("./bin/jcunit")
@@expectOutput("stderr")
There is no any requirement provided for test!

@@endtest

@whenRun("./bin/jcunit", args="--run-mode=detail --no-summary")
@expectOutput("stdout")
Test Suite: some-test.test
          PASS A passed test


@endtest


@test("It should suppress summary in detail mode with multiple tests and --no-summary")
@given("file", filename="some-test.test")

@@test("An incomplete test")
@@given("file")

@@@@test("Some test")
@@@@whenRun("./bin/jcunit")
@@@@endtest()

@@whenRun("./bin/jcunit")
@@endtest

@@test("A passed test")
@@given("file")

@@@@test()
@@@@endtest()

@@whenRun("./bin/jcunit")
@@expectOutput("stderr")
There is no any requirement provided for test!

@@endtest

@whenRun("./bin/jcunit", args="--run-mode=detail --no-summary")
@expectOutput("stdout")
Test Suite: some-test.test
    INCOMPLETE An incomplete test
          PASS A passed test


@endtest
