@test("It should run a program with @given none")
@given("none")
@whenRun("./testers/print-args", args="--help")
@expectOutput("stdout")
--help

@endtest

@test("It should run a program with @given none and without args")
@given("none")
@whenRun("./testers/print-args")
@expectOutput("stdout")
@endtest

@test("It should run a program with @given none with multiple args")
@given("none")
@whenRun("./testers/print-args", args="--flag1 --flag2 --flag3")
@expectOutput("stdout")
--flag1
--flag2
--flag3

@endtest

@test("It should check stderr with @given none")
@given("none")
@whenRun("./testers/print-to-stderr", args="--error")
@expectOutput("stderr")
--error

@endtest

@test("It should check both stdout and stderr with @given none")
@given("none")
@whenRun("./testers/dual-output.sh")
@expectOutput("stdout")
stdout line
@expectOutput("stderr")
stderr line
@endtest

@test("It should skip test with @given none")
@given("none")
@shouldBeSkipped
@whenRun("./testers/print-args", args="--help")
@expectOutput("stdout")
--help

@endtest

@test("It should pass referenced file path as first argument")
@given("reference", path="tests/fixtures/sample-input.txt")
@whenRun("./testers/print-args", args="--flag1")
@expectOutput("stdout")
tests/fixtures/sample-input.txt
--flag1

@endtest

@test("It should run jcunit on a referenced test file")
@given("reference", path="tests/fixtures/reference-inner.test")
@whenRun("./bin/jcunit", args="--no-cache")
@expectOutput("stdout")
.                                                  (100%)

Time: {{any}}
OK!
Passed: 1, Skipped: 0, Errors: 0, Failed: 0, Incomplete: 0

@endtest

@test("It should still work with @given file")
@given("file")
some content
@whenRun("./testers/print-args", args="--flag1")
@expectOutput("stdout")
{{any}}
--flag1

@endtest
